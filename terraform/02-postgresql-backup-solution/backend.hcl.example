# Example backend configuration for STATE 2.
# Copy to backend.hcl and fill approved values (backend.hcl is gitignored).
# Init with: terraform init -backend-config=backend.hcl
#
# NOTE: This uses the SAME backend storage account as State 1 but a DIFFERENT key,
# giving two independent state files. State permissions can still be scoped
# per-key/prefix using Azure RBAC + blob conditions.
resource_group_name  = "WW-Eanco-tfstate-RG"
storage_account_name = "steancotfstatedev"
container_name       = "tfstate"
use_azuread_auth     = true
