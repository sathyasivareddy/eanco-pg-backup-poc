# =============================================================================
# STATE 2 example variables — PLACEHOLDERS. Copy to terraform.tfvars and replace.
# Values marked "from State 1 output" come from `terraform output` of State 1.
# Never place passwords/keys/SAS in this file.
# =============================================================================

# subscription_id / tenant_id: prefer ARM_SUBSCRIPTION_ID / ARM_TENANT_ID env vars.

resource_group_name = "WW-EancoPostgreSQLBackupSolution-RG"
location            = "eastus2"

environment        = "dev"
naming_prefix      = "ww-eanco"
project_identifier = "eanco-pgbackup"
owner              = "platform-team@winwire.com"
cost_center        = "CC-EANCO-POC"
poc_expiry_date    = "2026-10-15"

enable_resource_locks = true

# ---- State 1 integration (explicit resource IDs) ----
postgresql_server_id      = "REPLACE_WITH_state1_output.postgresql_server_id"
postgresql_server_fqdn    = "REPLACE_WITH_state1_output.postgresql_server_fqdn"
postgresql_database_name  = "eanco_backup_demo"
postgresql_admin_username = "eanco_pgadmin"
virtual_network_id        = "REPLACE_WITH_state1_output.virtual_network_id"
container_apps_subnet_id  = "REPLACE_WITH_state1_output.container_apps_subnet_id"

# ---- Create vs reuse shared services ----
create_acr                     = true
create_storage_account         = true
create_key_vault               = true
create_log_analytics_workspace = true
create_action_group            = true

create_storage_private_endpoint   = false
create_key_vault_private_endpoint  = false
create_acr_private_endpoint        = false

# ---- ACR ----
acr_sku = "Basic"

# ---- Storage ----
storage_account_replication        = "LRS"
backup_container_name              = "postgres-backups"
storage_soft_delete_retention_days = 7
enable_blob_versioning             = false
enable_immutability                = false
lifecycle_delete_after_days        = 7
# lifecycle_tier_to_cool_days      = 7   # production example (leave null for POC)

# ---- Key Vault ----
key_vault_purge_protection_enabled   = false
key_vault_soft_delete_retention_days = 7
postgresql_password_secret_name      = "postgresql-backup-password"

# ---- Monitoring / alerts ----
log_analytics_retention_days = 30
alert_email_receivers = [
  { name = "platform-oncall", email = "platform-oncall@winwire.com" }
]
no_successful_backup_threshold_hours = 26
job_duration_alert_seconds           = 1800

# ---- Container Apps job ----
# container_image left null on first apply -> bootstrap image used; container-deploy
# workflow sets the real digest, e.g. "<acr>.azurecr.io/eanco-pg-backup@sha256:<digest>".
# container_image = null
job_cpu                     = 0.5
job_memory                  = "1Gi"
job_replica_timeout_seconds = 1800
job_replica_retry_limit     = 2
enable_backup_schedule      = false        # keep disabled until restore validation passes
backup_cron_expression      = "0 2 * * *"  # 02:00 UTC daily
backup_schedule_timezone    = "Etc/UTC"
postgresql_sslmode          = "require"
storage_blob_rbac_scope     = "container"
