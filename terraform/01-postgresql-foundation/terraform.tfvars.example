# =============================================================================
# STATE 1 example variables — PLACEHOLDERS. Copy to terraform.tfvars and replace
# with approved values. Do NOT commit real terraform.tfvars (gitignored).
# Tenant ID / Subscription ID are best supplied via ARM_TENANT_ID /
# ARM_SUBSCRIPTION_ID environment variables instead of this file.
# =============================================================================

# subscription_id = "dae60e3b-6b95-4e36-877f-50c54edcd377" # prefer ARM_SUBSCRIPTION_ID env
# tenant_id       = "<your-tenant-id>"                      # prefer ARM_TENANT_ID env

resource_group_name = "WW-EancoPostgreSQLBackupSolution-RG"
location            = "eastus2"

environment        = "dev"
naming_prefix      = "ww-eanco"
project_identifier = "eanco-pgbackup"
owner              = "platform-team@winwire.com"
cost_center        = "CC-EANCO-POC"
poc_expiry_date    = "2026-10-15"

additional_tags = {
  workload = "postgresql-backup-poc"
}

enable_resource_locks = true

# ---- Networking (create new VNet; CIDRs must be Network-team approved) ----
create_virtual_network       = true
create_postgresql_subnet     = true
create_container_apps_subnet = true
create_private_dns_zone      = true
create_private_dns_vnet_link = true

vnet_address_space         = ["10.59.0.0/22"]
postgresql_subnet_name     = "snet-postgresql"
postgresql_subnet_cidr     = "10.59.0.0/24"
container_apps_subnet_name = "snet-containerapps"
container_apps_subnet_cidr = "10.59.1.0/24"

# ---- PostgreSQL (POC sizing) ----
postgresql_version               = "16"
postgresql_sku_name              = "B_Standard_B1ms"
postgresql_storage_mb            = 32768
postgresql_backup_retention_days = 7
postgresql_geo_redundant_backup  = false
postgresql_high_availability     = false

postgresql_admin_username        = "eanco_pgadmin"
postgresql_password_auth_enabled = true
postgresql_entra_admin_enabled   = false

# OPTION A only: supply the admin password via TF_VAR_postgresql_admin_password
# (sourced from Key Vault) at plan/apply time. Never place it in this file.
# postgresql_admin_password = "DO_NOT_PUT_PASSWORD_HERE"

database_name      = "eanco_backup_demo"
database_charset   = "UTF8"
database_collation = "en_US.utf8"

# Diagnostics optional (only if required)
enable_postgresql_diagnostics = false
# diagnostics_log_analytics_workspace_id = "<law-resource-id>"
